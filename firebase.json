{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/.*/**",
      "**/node_modules/**",
      "**/.venv/**",
      "*.md",
      "*.sh",
      "*.pdf",
      "server.js",
      "decoded_pdf_text.txt",
      "extracted_text.txt"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
